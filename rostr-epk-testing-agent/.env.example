# Target deployment URL (default: http://localhost:3000 for local dev)
# Set to your live deployment URL, e.g. https://artistsepks.vercel.app
SITE_URL=http://localhost:3000

# Request timeout in milliseconds (default: 30000)
TEST_TIMEOUT=30000

# Optional: Test credentials for auth flow
TEST_EMAIL=test@example.com
TEST_PASSWORD=your-test-password

# Optional: API keys for integration tests
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
PEXELS_API_KEY=
OBSCURA_PATH=./bin/obscura
