# Per-EPK pricing (one-time payment products in Stripe)
STRIPE_PRICE_EPK_EDIT=price_xxx          # $9.99 — Edit Access
STRIPE_PRICE_EPK_STYLE_PRO=price_xxx     # $20   — Style Pro
STRIPE_PRICE_EPK_PREMIUM=price_xxx       # $49   — Premium

# ── Optional: Spotify ──────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=
