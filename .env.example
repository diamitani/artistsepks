# ── Required: AI Provider ──────────────────────────────────────────────────────
# DeepSeek (recommended — cheap, strong function calling)
# Get a key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
AI_PROVIDER=deepseek

# OR Gemini (fallback)
# GEMINI_API_KEY=
# AI_PROVIDER=gemini

# OR Claude (fallback)
# ANTHROPIC_DIRECT_API_KEY=
# ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-5
# AI_PROVIDER=claude

# ── Required: Supabase ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Optional: Spotify (for auto-discography pull) ──────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Optional: Pexels (for free stock hero images) ──────────────────────────────
PEXELS_API_KEY=

# ── Optional: Obscura headless browser (for social scraping) ───────────────────
OBSCURA_PATH=./bin/obscura
