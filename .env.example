# ── Required: AI Provider ──────────────────────────────────────────────────────
# DeepSeek (recommended — cheap, strong function calling)
# Get a key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
AI_PROVIDER=deepseek

# OR Gemini (fallback)
# GEMINI_API_KEY=
# AI_PROVIDER=gemini

# OR Claude (fallback)
# ANTHROPIC_DIRECT_API_KEY=
# ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-5
# AI_PROVIDER=claude

# ── Required: Supabase ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Required: Stripe ───────────────────────────────────────────────────────────
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Price IDs — create these in Stripe Dashboard (Products > Pricing)
# One-time payment product
STRIPE_PRICE_EPK_ONETIME=price_xxx
# Subscription products
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_YEARLY=price_xxx

# ── Optional: Spotify (for auto-discography pull) ──────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Optional: Pexels (for free stock hero images) ──────────────────────────────
PEXELS_API_KEY=
